RewriteEngine On
# Serve extensionless URLs if the corresponding .html file exists
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^.]+)$ $1.html [L]
# Redirect .html URLs to their extensionless versions
RewriteCond %{THE_REQUEST} \s/+([^\s]+?)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/wildewes/ChatApp"
PassengerBaseURI "/"
PassengerNodejs "/home/wildewes/nodevenv/ChatApp/22/bin/node"
PassengerAppType node
PassengerStartupFile server.js
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END
